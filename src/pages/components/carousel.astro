---
import CarouselDemo from '../../components/docs/CarouselDemo';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Carousel" description="アクセシブルなカルーセルコンポーネントの実装例">
  <h1 class="text-4xl mb-4">Carousel</h1>
  <p class="mb-4 leading-relaxed text-sm">
    スライドコンテンツを順番に表示するカルーセルコンポーネント。
    自動再生なし・キーボード操作対応・スクリーンリーダーへのスライド変更通知に対応しています。
  </p>
  <a
    href="https://github.com/yamanoku/react-tokyo-fes-2026/blob/main/src/components/ui/Carousel.tsx"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-sm mb-12"
  >
    Carousel.tsx
  </a>
  <CarouselDemo client:load />
</BaseLayout>
