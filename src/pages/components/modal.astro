---
import ModalDemo from '../../components/docs/ModalDemo';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Modal" description="アクセシブルなモーダルダイアログの実装例">
  <h1 class="text-4xl mb-4">Modal</h1>
  <p class="mb-4 leading-relaxed text-sm">
    フォーカストラップ、キーボード操作、フォーカス復帰に対応したアクセシブルなモーダルダイアログコンポーネント。
  </p>
  <a
    href="https://github.com/yamanoku/react-tokyo-fes-2026/blob/main/src/components/ui/Modal.tsx"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-sm mb-12"
  >
    Modal.tsx
  </a>
  <ModalDemo client:load />
</BaseLayout>
